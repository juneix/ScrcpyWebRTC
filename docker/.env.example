# CloudPhone 云服务器 Docker 部署环境变量配置模板
# 部署时请拷贝并重命名为 .env，或运行 ./deploy_cloud.sh 自动生成

# 云服务器公网 IP (必须填对，用于 WebRTC 媒体路由与 ICE 候选地址发布)
PUBLIC_IP=127.0.0.1

# TURN/STUN 静态中转服务的认证用户名和密码
TURN_USER=cloudphone_user
TURN_PASSWORD=cloudphone_secure_password

# 信令及网页管理服务端口
SIGNALING_PORT=8443

# 前端版本：v1 (经典版) 或 v2 (全新精美版)
UI_VERSION=v1

# 默认全局及虚机连接参数配置 (JSON)
# 默认：最高码率 4Mbps, 最低码率 1Mbps, 帧率 30fps, 限制分辨率长边 1920px
DEFAULT_SETTINGS={"maxBitrate":4,"minBitrate":1,"fps":30,"size":1920,"bitrate":4}
